NEXT_PUBLIC_CURRENCY=usd

# Server-only (e.g. .env.local): cache AI repo summaries on the `repos` document
APPWRITE_API_KEY=

# Optional: OpenAI API key for /api/repos/[id]/summary (gpt-4o-mini). Without it, a text fallback is used.
OPENAI_API_KEY=

# Stripe (set these as Appwrite function variables on `openget-api`, not just in .env.local).
# STRIPE_SECRET_KEY    - Dashboard -> Developers -> API keys (use sk_test_... until live).
# STRIPE_WEBHOOK_SECRET - Dashboard -> Developers -> Webhooks -> endpoint signing secret.
# STRIPE_CONNECT_*_URL  - Where the Express onboarding flow redirects contributors back to.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CONNECT_REFRESH_URL=http://localhost:3000/dashboard
STRIPE_CONNECT_RETURN_URL=http://localhost:3000/dashboard
