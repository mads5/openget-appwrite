NEXT_PUBLIC_CURRENCY=usd

# Copy this file to `.env.local` in the repo root (gitignored) for local tooling.
# Required for: `npm run db:sync`, `npm run deploy:api` (loads automatically via scripts/load-env.mjs).

# Server-only: Appwrite (Next.js server routes and scripts use the REST API with this key; keep secret).
# Do not expose in client bundles. Used for /api/verify, /api/badge/*, and db:sync.
APPWRITE_API_KEY=

# Comma-separated API keys for optional keyed access to public verification JSON (e.g. B2B). Configure on
# hosting / Appwrite or Next env as applicable to your deployment.
# OPENGET_VERIFY_API_KEYS=

# Optional: OpenAI API key for /api/repos/[id]/summary (gpt-4o-mini). Without it, a text fallback is used.
OPENAI_API_KEY=

# Public site URL for legal pages (defaults to Appwrite Site if unset).
# NEXT_PUBLIC_SITE_URL=https://openget.appwrite.network

# Optional: README "Environment variables" anchor (dashboard notice when /api/badge needs APPWRITE_API_KEY on the host).
# NEXT_PUBLIC_README_ENV_URL=https://github.com/your-org/openget-appwrite/blob/main/README.md#environment-variables

# Public legal copy on /legal/terms and /legal/privacy (optional — defaults exist in src/lib/legal-info.ts).
# NEXT_PUBLIC_LEGAL_ENTITY_NAME=
# NEXT_PUBLIC_LEGAL_REGISTERED_ADDRESS=
NEXT_PUBLIC_LEGAL_CONTACT_EMAIL=veerkalantri1+openget@gmail.com
NEXT_PUBLIC_GOVERNING_LAW=India
