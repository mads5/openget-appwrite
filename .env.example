NEXT_PUBLIC_CURRENCY=usd

# Server-only (e.g. .env.local): cache AI repo summaries on the `repos` document
APPWRITE_API_KEY=

# Optional: OpenAI API key for /api/repos/[id]/summary (gpt-4o-mini). Without it, a text fallback is used.
OPENAI_API_KEY=

# Razorpay — set on Appwrite function `openget-api` (and optional public key for the Next.js app).
# RAZORPAY_KEY_ID / RAZORPAY_KEY_SECRET — API keys (Dashboard → Developers → API keys).
# RAZORPAY_WEBHOOK_SECRET — Webhooks → endpoint signing secret (events: payment.captured, order.paid, payout.*).
# NEXT_PUBLIC_RAZORPAY_KEY_ID — same as Key ID (safe to expose; used by hosted Checkout in the browser).
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
NEXT_PUBLIC_RAZORPAY_KEY_ID=

# RazorpayX bank payouts (optional — weekly contributor payouts).
# RAZORPAYX_ACCOUNT_NUMBER — business account number from RazorpayX dashboard.
# RAZORPAYX_PAYOUT_CURRENCY — must match how pool amounts are denominated (often INR).
# RAZORPAYX_PAYOUT_MODE — e.g. IMPS, NEFT (region-specific).
RAZORPAYX_ACCOUNT_NUMBER=
RAZORPAYX_PAYOUT_CURRENCY=INR
RAZORPAYX_PAYOUT_MODE=IMPS

# Public site URL for legal pages (defaults to Appwrite Site if unset).
# NEXT_PUBLIC_SITE_URL=https://openget.appwrite.network

# Public legal copy on /legal/terms and /legal/privacy (optional — defaults exist in src/lib/legal-info.ts).
# NEXT_PUBLIC_LEGAL_ENTITY_NAME=
# NEXT_PUBLIC_LEGAL_REGISTERED_ADDRESS=
NEXT_PUBLIC_LEGAL_CONTACT_EMAIL=veerkalantri1+openget@gmail.com
NEXT_PUBLIC_GOVERNING_LAW=India
